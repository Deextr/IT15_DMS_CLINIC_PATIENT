@model DMS_CPMS.Models.SuperAdmin.CreateAccountViewModel

<div class="modal fade" id="createStaffModal" tabindex="-1" aria-labelledby="createStaffModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content ocean-modal">
            <div class="modal-header">
                <h5 class="modal-title" id="createStaffModalLabel">Create Staff Account</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-area="Admin" asp-action="Create" asp-controller="Accounts" method="post" novalidate>
                <div class="modal-body">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-2" role="alert"></div>

                    <input type="hidden" asp-for="RoleType" value="Staff" />

                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="infield">
                                <input asp-for="FirstName" class="form-control" />
                                <label asp-for="FirstName" class="infield-label"></label>
                            </div>
                            <span asp-validation-for="FirstName" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <div class="infield">
                                <input asp-for="LastName" class="form-control" />
                                <label asp-for="LastName" class="infield-label"></label>
                            </div>
                            <span asp-validation-for="LastName" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <div class="infield">
                                <input class="form-control" value="Staff" disabled />
                                <label class="infield-label">Role Type</label>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="infield">
                                <input asp-for="Username" class="form-control" />
                                <label asp-for="Username" class="infield-label"></label>
                            </div>
                            <span asp-validation-for="Username" class="text-danger"></span>
                        </div>
                        <div class="col-12">
                            <div class="infield">
                                <input asp-for="Password" class="form-control" data-password-hint="true" />
                                <label asp-for="Password" class="infield-label"></label>
                            </div>
                            <span asp-validation-for="Password" class="text-danger"></span>
                            <small class="password-hint">Minimum 8 characters, with uppercase, lowercase, number, and special character.</small>
                        </div>
                        <div class="col-12">
                            <div class="infield">
                                <input asp-for="ConfirmPassword" class="form-control" />
                                <label asp-for="ConfirmPassword" class="infield-label"></label>
                            </div>
                            <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Create Staff Account</button>
                </div>
            </form>
        </div>
    </div>
</div>

