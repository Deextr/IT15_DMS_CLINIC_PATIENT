@model EditAccountViewModel
@{
    ViewData["Title"] = "Edit Account";
}

<div class="container-fluid">
    <h1 class="mb-3">Edit Account</h1>
    <p class="text-muted mb-4">Update account details. Leave password fields blank to keep the current password.</p>

    <div class="row">
        <div class="col-md-6 col-lg-5">
            <form asp-area="SuperAdmin" asp-controller="Accounts" asp-action="Edit" method="post" novalidate>
                <input type="hidden" asp-for="Id" />
                <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                <div class="infield mb-3">
                    <input asp-for="FirstName" class="form-control" />
                    <label asp-for="FirstName" class="infield-label"></label>
                    <span asp-validation-for="FirstName" class="text-danger"></span>
                </div>

                <div class="infield mb-3">
                    <input asp-for="LastName" class="form-control" />
                    <label asp-for="LastName" class="infield-label"></label>
                    <span asp-validation-for="LastName" class="text-danger"></span>
                </div>

                <div class="infield mb-3">
                    <input asp-for="Username" class="form-control" />
                    <label asp-for="Username" class="infield-label"></label>
                    <span asp-validation-for="Username" class="text-danger"></span>
                </div>

                <div class="infield mb-3">
                    <select asp-for="RoleType" class="form-select">
                        <option value="Admin">Admin</option>
                        <option value="Staff">Staff</option>
                    </select>
                    <label asp-for="RoleType" class="infield-label"></label>
                </div>

                <div class="mb-3 form-check">
                    <input asp-for="IsActive" class="form-check-input" />
                    <label asp-for="IsActive" class="form-check-label"></label>
                </div>

                <div class="infield mb-3">
                    <input asp-for="NewPassword" class="form-control" autocomplete="new-password" data-password-hint="true" />
                    <label asp-for="NewPassword" class="infield-label"></label>
                    <span asp-validation-for="NewPassword" class="text-danger"></span>
                    <small class="password-hint">Minimum 8 characters, with uppercase, lowercase, number, and special character.</small>
                </div>

                <div class="infield mb-3">
                    <input asp-for="ConfirmPassword" class="form-control" autocomplete="new-password" />
                    <label asp-for="ConfirmPassword" class="infield-label"></label>
                    <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                </div>

                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn btn-primary">Save changes</button>
                    <a asp-area="SuperAdmin" asp-controller="Accounts" asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
