@model DMS_CPMS.Models.Accounts.AccountsIndexViewModel
@{
    ViewData["Title"] = "Manage Accounts";
    var currentUserId = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
}

<div class="container-fluid">
    @if (TempData["StatusMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="me-2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
            @TempData["StatusMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="me-2"><circle cx="12" cy="12" r="10"></circle><line x1="15" y1="9" x2="9" y2="15"></line><line x1="9" y1="9" x2="15" y2="15"></line></svg>
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    <!-- Create Account Button - Outside Table Container -->
    <div class="d-flex justify-content-start mb-2">
        <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createAccountModal">
            + Create Account
        </button>
    </div>

    <div class="card shadow-sm border-0 mb-3">
        <div class="card-body">
            <!-- Search & Filters -->
            <form class="row g-2 align-items-end mb-3" method="get" asp-area="SuperAdmin" asp-action="Index" asp-controller="Accounts">
                <div class="col-md-5">
                    <label class="form-label">Search by name/username</label>
                    <input type="text" name="searchTerm" value="@Model.SearchTerm" class="form-control" placeholder="Enter name or username" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Role</label>
                    <select name="role" class="form-select">
                        <option value="">All</option>
                        <option value="Admin" selected="@(Model.RoleFilter == "Admin" ? "selected" : null)">Admin</option>
                        <option value="Staff" selected="@(Model.RoleFilter == "Staff" ? "selected" : null)">Staff</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Status</label>
                    <select name="status" class="form-select">
                        <option value="">All</option>
                        <option value="Active" selected="@(Model.StatusFilter == "Active" ? "selected" : null)">Active</option>
                        <option value="Inactive" selected="@(Model.StatusFilter == "Inactive" ? "selected" : null)">Inactive</option>
                    </select>
                </div>
                <div class="col-md-3 d-flex align-items-end gap-2">
                    <button type="submit" class="btn btn-secondary flex-fill">Filter</button>
                    <a asp-area="SuperAdmin" asp-action="Index" asp-controller="Accounts" class="btn btn-outline-secondary flex-fill">Reset</a>
                </div>
            </form>

            <div class="table-responsive" id="accounts-table">
                <table class="table documents-table align-middle mb-0">
                    <thead>
                        <tr>
                            <th style="width: 25%;">Username</th>
                            <th style="width: 25%;">Full Name</th>
                            <th style="width: 15%;">Role</th>
                            <th style="width: 15%;">Status</th>
                            <th style="width: 20%;" class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Accounts.Any())
                        {
                            <tr>
                                <td colspan="5" class="text-center text-muted py-4">
                                    No accounts found. Use the button above to create a new account.
                                </td>
                            </tr>
                        }
                        else
                        {
                            foreach (var item in Model.Accounts)
                            {
                            <tr>
                                <td>@item.Username</td>
                                <td>@item.FullName</td>
                                <td><span style="color: var(--color-primary); font-weight: 700;">@item.Role</span></td>
                                <td>
                                    @if (item.IsActive)
                                    {
                                        <span style="display: inline-flex; align-items: center; gap: 6px;"><span style="width: 10px; height: 10px; border-radius: 50%; background-color: #198754; display: inline-block;"></span><span style="color: #000;">Active</span></span>
                                    }
                                    else
                                    {
                                        <span style="display: inline-flex; align-items: center; gap: 6px;"><span style="width: 10px; height: 10px; border-radius: 50%; background-color: #6c757d; display: inline-block;"></span><span style="color: #000;">Deactivated</span></span>
                                    }
                                </td>
                                <td class="text-center">
                                    <div class="d-inline-flex gap-1">
                                        <button type="button"
                                                class="btn btn-sm"
                                                style="border: 1px solid var(--color-primary); color: var(--color-primary); background: transparent;"
                                                onmouseover="this.style.background='var(--color-primary)'; this.style.color='#fff';"
                                                onmouseout="this.style.background='transparent'; this.style.color='var(--color-primary)';"
                                                data-bs-toggle="tooltip"
                                                data-bs-placement="top"
                                                title="Edit Account"
                                                data-modal-toggle="modal"
                                                data-modal-target="#editAccountModal"
                                                data-id="@item.Id"
                                                data-username="@item.Username"
                                                data-fullname="@item.FullName"
                                                data-role="@item.Role"
                                                data-isactive="@(item.IsActive.ToString().ToLowerInvariant())"
                                                onclick="openEditAccountModal(this)">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
                                        </button>
                                        @if (item.Id != currentUserId)
                                        {
                                            @if (item.IsActive)
                                            {
                                                <button type="button"
                                                        class="btn btn-sm"
                                                        style="border: 1px solid var(--color-primary); color: var(--color-primary); background: transparent;"
                                                        onmouseover="this.style.background='var(--color-primary)'; this.style.color='#fff';"
                                                        onmouseout="this.style.background='transparent'; this.style.color='var(--color-primary)';"
                                                        data-bs-toggle="tooltip"
                                                        data-bs-placement="top"
                                                        title="Deactivate Account"
                                                        data-id="@item.Id"
                                                        data-name="@item.FullName"
                                                        onclick="openDeactivateModal(this)">
                                                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"></line></svg>
                                                </button>
                                            }
                                            else
                                            {
                                                <button type="button"
                                                        class="btn btn-sm"
                                                        style="border: 1px solid var(--color-primary); color: var(--color-primary); background: transparent;"
                                                        onmouseover="this.style.background='var(--color-primary)'; this.style.color='#fff';"
                                                        onmouseout="this.style.background='transparent'; this.style.color='var(--color-primary)';"
                                                        data-bs-toggle="tooltip"
                                                        data-bs-placement="top"
                                                        title="Activate Account"
                                                        data-id="@item.Id"
                                                        data-name="@item.FullName"
                                                        onclick="openActivateModal(this)">
                                                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
                                                </button>
                                            }
                                            <button type="button"
                                                    class="btn btn-sm"
                                                    style="border: 1px solid var(--color-primary); color: var(--color-primary); background: transparent;"
                                                    onmouseover="this.style.background='var(--color-primary)'; this.style.color='#fff';"
                                                    onmouseout="this.style.background='transparent'; this.style.color='var(--color-primary)';"
                                                    data-bs-toggle="tooltip"
                                                    data-bs-placement="top"
                                                    title="Archive Account"
                                                    data-id="@item.Id"
                                                    data-name="@item.FullName"
                                                    onclick="openArchiveModal(this)">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 8v13H3V8"></path><path d="M1 3h22v5H1z"></path><path d="M10 12h4"></path></svg>
                                            </button>
                                        }
                                    </div>
                                </td>
                            </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
            <!-- Table Footer with Pagination - Standardized Style -->
            <div class="table-footer">
                <div class="table-footer-left">
                    <span class="text-muted small">Showing @(Model.TotalCount > 0 ? (Model.PageNumber - 1) * Model.PageSize + 1 : 0) to @Math.Min(Model.PageNumber * Model.PageSize, Model.TotalCount) of @Model.TotalCount entries</span>
                </div>
                <div class="table-footer-right">
                    <nav class="pagination-nav">
                        <a asp-area="SuperAdmin" asp-action="Index" asp-controller="Accounts" asp-route-page="1" asp-route-searchTerm="@Model.SearchTerm" asp-route-role="@Model.RoleFilter" asp-route-status="@Model.StatusFilter"
                           asp-fragment="accounts-table"
                           class="btn btn-sm btn-outline-secondary pagination-btn @(Model.PageNumber <= 1 ? "disabled" : "")" title="First Page">&laquo;</a>
                        <a asp-area="SuperAdmin" asp-action="Index" asp-controller="Accounts" asp-route-page="@(Model.PageNumber - 1)" asp-route-searchTerm="@Model.SearchTerm" asp-route-role="@Model.RoleFilter" asp-route-status="@Model.StatusFilter"
                           asp-fragment="accounts-table"
                           class="btn btn-sm btn-outline-secondary pagination-btn @(Model.PageNumber <= 1 ? "disabled" : "")" title="Previous">&lsaquo;</a>
                        <span class="pagination-indicator">@Model.PageNumber / @Math.Max(Model.TotalPages, 1)</span>
                        <a asp-area="SuperAdmin" asp-action="Index" asp-controller="Accounts" asp-route-page="@(Model.PageNumber + 1)" asp-route-searchTerm="@Model.SearchTerm" asp-route-role="@Model.RoleFilter" asp-route-status="@Model.StatusFilter"
                           asp-fragment="accounts-table"
                           class="btn btn-sm btn-outline-secondary pagination-btn @(Model.PageNumber >= Model.TotalPages ? "disabled" : "")" title="Next">&rsaquo;</a>
                        <a asp-area="SuperAdmin" asp-action="Index" asp-controller="Accounts" asp-route-page="@Model.TotalPages" asp-route-searchTerm="@Model.SearchTerm" asp-route-role="@Model.RoleFilter" asp-route-status="@Model.StatusFilter"
                           asp-fragment="accounts-table"
                           class="btn btn-sm btn-outline-secondary pagination-btn @(Model.PageNumber >= Model.TotalPages ? "disabled" : "")" title="Last Page">&raquo;</a>
                    </nav>
                </div>
            </div>
        </div>
    </div>
</div>

@await Html.PartialAsync("~/Views/SuperAdmin/Accounts/_CreateAccountModal.cshtml", Model.NewAccount)
@await Html.PartialAsync("~/Views/SuperAdmin/Accounts/_EditAccountModal.cshtml", new DMS_CPMS.Models.Accounts.EditAccountViewModel())

<div class="modal fade" id="deactivateModal" tabindex="-1" aria-labelledby="deactivateModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content ocean-modal">
            <div class="modal-header">
                <h5 class="modal-title" id="deactivateModalLabel">Confirm deactivation</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to deactivate <strong id="deactivateUserName"></strong>? They will not be able to log in.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <form id="deactivateForm" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" id="deactivateUserId" />
                    <button type="submit" class="btn btn-danger">Deactivate account</button>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="activateModal" tabindex="-1" aria-labelledby="activateModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content ocean-modal">
            <div class="modal-header">
                <h5 class="modal-title" id="activateModalLabel">Confirm activation</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to activate <strong id="activateUserName"></strong>? They will be able to log in again.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <form id="activateForm" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" id="activateUserId" />
                    <button type="submit" class="btn btn-success">Activate account</button>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="archiveModal" tabindex="-1" aria-labelledby="archiveModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content ocean-modal">
            <div class="modal-header">
                <h5 class="modal-title" id="archiveModalLabel">Archive account</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to archive <strong id="archiveUserName"></strong>? The account will be deactivated and moved to the archive.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <form id="archiveForm" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" id="archiveUserId" />
                    <button type="submit" class="btn btn-danger">Archive account</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // Initialize Bootstrap tooltips
        document.addEventListener('DOMContentLoaded', function () {
            var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
            var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
                return new bootstrap.Tooltip(tooltipTriggerEl);
            });
        });

        function openDeactivateModal(btn) {
            var id = btn.getAttribute('data-id');
            var name = btn.getAttribute('data-name');
            document.getElementById('deactivateUserId').value = id || '';
            document.getElementById('deactivateUserName').textContent = name || '';
            var form = document.getElementById('deactivateForm');
            if (form) form.action = '@Url.Action("Deactivate", "Accounts", new { area = "SuperAdmin" })?id=' + encodeURIComponent(id || '');
            var modal = new bootstrap.Modal(document.getElementById('deactivateModal'));
            modal.show();
        }

        function openActivateModal(btn) {
            var id = btn.getAttribute('data-id');
            var name = btn.getAttribute('data-name');
            document.getElementById('activateUserId').value = id || '';
            document.getElementById('activateUserName').textContent = name || '';
            var form = document.getElementById('activateForm');
            if (form) form.action = '@Url.Action("Activate", "Accounts", new { area = "SuperAdmin" })?id=' + encodeURIComponent(id || '');
            var modal = new bootstrap.Modal(document.getElementById('activateModal'));
            modal.show();
        }

        function openArchiveModal(btn) {
            var id = btn.getAttribute('data-id');
            var name = btn.getAttribute('data-name');
            document.getElementById('archiveUserId').value = id || '';
            document.getElementById('archiveUserName').textContent = name || '';
            var form = document.getElementById('archiveForm');
            if (form) form.action = '@Url.Action("ArchiveAccount", "Accounts", new { area = "SuperAdmin" })?id=' + encodeURIComponent(id || '');
            var modal = new bootstrap.Modal(document.getElementById('archiveModal'));
            modal.show();
        }

        function openEditAccountModal(btn) {
            var id = btn.getAttribute('data-id') || '';
            var username = btn.getAttribute('data-username') || '';
            var fullName = btn.getAttribute('data-fullname') || '';
            var role = btn.getAttribute('data-role') || 'Staff';
            var isActive = btn.getAttribute('data-isactive') === 'true';

            var firstName = '';
            var lastName = '';
            if (fullName) {
                var parts = fullName.trim().split(' ');
                firstName = parts[0] || '';
                if (parts.length > 1) {
                    lastName = parts.slice(1).join(' ');
                }
            }

            var editModal = document.getElementById('editAccountModal');
            var modalBody = editModal;
            var idInput = modalBody.querySelector('input[name="Id"]');
            var firstInput = modalBody.querySelector('input[name="FirstName"]');
            var lastInput = modalBody.querySelector('input[name="LastName"]');
            var usernameInput = modalBody.querySelector('input[name="Username"]');
            var roleSelect = modalBody.querySelector('select[name="RoleType"]');
            var isActiveInput = modalBody.querySelector('input[name="IsActive"]');
            var newPassInput = modalBody.querySelector('input[name="NewPassword"]');
            var confirmPassInput = modalBody.querySelector('input[name="ConfirmPassword"]');

            if (idInput) idInput.value = id;
            if (firstInput) firstInput.value = firstName;
            if (lastInput) lastInput.value = lastName;
            if (usernameInput) usernameInput.value = username;
            if (roleSelect) roleSelect.value = role;
            if (isActiveInput) isActiveInput.checked = isActive;
            if (newPassInput) newPassInput.value = '';
            if (confirmPassInput) confirmPassInput.value = '';

            var modal = new bootstrap.Modal(editModal);
            modal.show();
        }
    </script>
}
