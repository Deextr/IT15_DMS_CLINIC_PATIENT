@model DMS_CPMS.Models.Patient.CreatePatientViewModel
@using System.Security.Claims
@{
    var createUserRole = User.IsInRole("SuperAdmin") ? "SuperAdmin" : User.IsInRole("Admin") ? "Admin" : User.IsInRole("Staff") ? "Staff" : "User";
}

<div class="modal fade" id="createPatientModal" tabindex="-1" aria-labelledby="createPatientModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content ocean-modal">
            <div class="modal-header">
                <h5 class="modal-title" id="createPatientModalLabel">New Patient</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="createPatientForm" asp-action="Create" asp-controller="Patient" method="post" enctype="multipart/form-data">
                <div class="modal-body">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="createPatientSourceType" name="DocumentSourceType" value="device" />
                    <input type="hidden" id="createPatientGoogleFileId" name="GoogleDriveFileId" />
                    <input type="hidden" id="createPatientGoogleAccessToken" name="GoogleDriveAccessToken" />
                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="infield">
                                <input asp-for="FirstName" class="form-control" />
                                <label asp-for="FirstName" class="infield-label"></label>
                            </div>
                            <span asp-validation-for="FirstName" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <div class="infield">
                                <input asp-for="LastName" class="form-control" />
                                <label asp-for="LastName" class="infield-label"></label>
                            </div>
                            <span asp-validation-for="LastName" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <div class="infield">
                                <input asp-for="BirthDate" type="date" class="form-control" />
                                <label asp-for="BirthDate" class="infield-label"></label>
                            </div>
                            <span asp-validation-for="BirthDate" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <div class="infield">
                                <select asp-for="Gender" class="form-select">
                                    <option value="">Select gender</option>
                                    <option value="Male">Male</option>
                                    <option value="Female">Female</option>
                                </select>
                                <label asp-for="Gender" class="infield-label"></label>
                            </div>
                            <span asp-validation-for="Gender" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <div class="infield">
                                <input asp-for="VisitedAt" type="datetime-local" class="form-control" />
                                <label asp-for="VisitedAt" class="infield-label"></label>
                            </div>
                            <span asp-validation-for="VisitedAt" class="text-danger"></span>
                        </div>

                        <!-- Upload Source Selection -->
                        <div class="col-12">
                            <label class="form-label">Upload Document <span class="text-muted">(optional)</span></label>
                            <div class="upload-source-options">
                                <!-- Option 1: Device Upload -->
                                <div class="upload-source-card active" id="createSourceDeviceCard" onclick="createSelectUploadSource('device')">
                                    <div class="upload-source-radio">
                                        <input type="radio" name="createUploadSource" value="device" checked class="form-check-input" id="createSourceDeviceRadio">
                                    </div>
                                    <div class="upload-source-content">
                                        <div class="upload-source-icon">
                                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="20" height="20">
                                                <rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect>
                                                <line x1="8" y1="21" x2="16" y2="21"></line>
                                                <line x1="12" y1="17" x2="12" y2="21"></line>
                                            </svg>
                                        </div>
                                        <div>
                                            <span class="upload-source-title">Choose from Device</span>
                                            <span class="upload-source-desc">Upload from your local storage</span>
                                        </div>
                                    </div>
                                </div>

                                @if (createUserRole == "SuperAdmin" || createUserRole == "Admin")
                                {
                                <!-- Option 2: Google Drive -->
                                <div class="upload-source-card" id="createSourceGoogleCard" onclick="createSelectUploadSource('googledrive')">
                                    <div class="upload-source-radio">
                                        <input type="radio" name="createUploadSource" value="googledrive" class="form-check-input" id="createSourceGoogleRadio">
                                    </div>
                                    <div class="upload-source-content">
                                        <div class="upload-source-icon">
                                            <svg viewBox="0 0 24 24" width="20" height="20" fill="none">
                                                <path d="M12 2L2 19.5h7.5L12 14l2.5 5.5H22L12 2z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
                                                <path d="M7 12.5L2 19.5h20l-5-7H7z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
                                            </svg>
                                        </div>
                                        <div>
                                            <span class="upload-source-title">Choose from Google Drive</span>
                                            <span class="upload-source-desc">Select a file from your Drive</span>
                                        </div>
                                    </div>
                                </div>
                                }
                            </div>
                        </div>

                        <!-- Device File Input (shown by default) -->
                        <div class="col-12" id="createDeviceFileSection">
                            <input asp-for="UploadedFile" type="file" id="createPatientFileInput" class="form-control" accept=".pdf,.jpg,.jpeg,.png,.gif,.csv,.txt,.doc,.docx,.xls,.xlsx" />
                            <small class="text-muted d-block mt-1">Allowed: PDF, Images, DOC, DOCX, XLS, XLSX, CSV, TXT</small>
                        </div>

                        <!-- Google Drive Picker Section (hidden by default) -->
                        <div class="col-12" id="createGoogleDriveSection" style="display: none;">
                            <div class="google-drive-picker-area">
                                <button type="button" class="btn btn-outline-primary w-100" id="createGoogleDrivePickerBtn" onclick="createOpenGoogleDrivePicker()">
                                    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" class="me-2">
                                        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                                        <polyline points="17 8 12 3 7 8"></polyline>
                                        <line x1="12" y1="3" x2="12" y2="15"></line>
                                    </svg>
                                    Select from Google Drive
                                </button>
                                <!-- Selected file indicator -->
                                <div class="google-drive-selected-file" id="createGoogleDriveSelectedFile" style="display: none;">
                                    <div class="selected-file-info">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16" class="me-2">
                                            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                                            <polyline points="14 2 14 8 20 8"></polyline>
                                        </svg>
                                        <span id="createGoogleDriveFileName" class="text-truncate"></span>
                                    </div>
                                    <button type="button" class="btn btn-sm btn-outline-secondary" onclick="createClearGoogleDriveSelection()" title="Remove selection">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14">
                                            <line x1="18" y1="6" x2="6" y2="18"></line>
                                            <line x1="6" y1="6" x2="18" y2="18"></line>
                                        </svg>
                                    </button>
                                </div>
                                <!-- Loading state -->
                                <div class="google-drive-loading" id="createGoogleDriveLoading" style="display: none;">
                                    <span class="spinner-border spinner-border-sm me-2"></span>
                                    <span>Connecting to Google Drive...</span>
                                </div>
                                <!-- Error state -->
                                <div class="google-drive-error" id="createGoogleDriveError" style="display: none;">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14" height="14" class="me-1">
                                        <circle cx="12" cy="12" r="10"></circle>
                                        <line x1="12" y1="8" x2="12" y2="12"></line>
                                        <line x1="12" y1="16" x2="12.01" y2="16"></line>
                                    </svg>
                                    <span id="createGoogleDriveErrorMsg"></span>
                                </div>
                            </div>
                            <small class="text-muted d-block mt-1">Allowed: PDF, Images, DOC, DOCX, XLS, XLSX, CSV, TXT</small>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary" id="createPatientSubmitBtn">Create Patient</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    // ── Create Patient modal – upload source toggle ──────────────────────────
    function createSelectUploadSource(source) {
        var deviceCard = document.getElementById('createSourceDeviceCard');
        var googleCard = document.getElementById('createSourceGoogleCard');
        var deviceSection = document.getElementById('createDeviceFileSection');
        var googleSection = document.getElementById('createGoogleDriveSection');
        var sourceInput = document.getElementById('createPatientSourceType');
        var fileInput = document.getElementById('createPatientFileInput');

        if (source === 'device') {
            deviceCard && deviceCard.classList.add('active');
            googleCard && googleCard.classList.remove('active');
            var dr = document.getElementById('createSourceDeviceRadio');
            if (dr) dr.checked = true;
            if (deviceSection) deviceSection.style.display = 'block';
            if (googleSection) googleSection.style.display = 'none';
            if (sourceInput) sourceInput.value = 'device';
            createClearGoogleDriveSelection();
        } else if (source === 'googledrive') {
            googleCard && googleCard.classList.add('active');
            deviceCard && deviceCard.classList.remove('active');
            var gr = document.getElementById('createSourceGoogleRadio');
            if (gr) gr.checked = true;
            if (googleSection) googleSection.style.display = 'block';
            if (deviceSection) deviceSection.style.display = 'none';
            if (sourceInput) sourceInput.value = 'googledrive';
            if (fileInput) { fileInput.value = ''; }
        }
    }

    // ── Google Drive picker for Create Patient ───────────────────────────────
    var createGoogleAccessToken = null;
    var createGoogleTokenClient = null;
    var createPickerApiLoaded = false;

    async function createOpenGoogleDrivePicker() {
        var loadingEl = document.getElementById('createGoogleDriveLoading');
        var errorEl = document.getElementById('createGoogleDriveError');
        var pickerBtn = document.getElementById('createGoogleDrivePickerBtn');

        errorEl.style.display = 'none';

        try {
            loadingEl.style.display = 'flex';
            pickerBtn.disabled = true;

            // Reuse the loadGoogleDriveConfig / loadGoogleScripts from google-drive-picker.js
            var config = await loadGoogleDriveConfig();
            if (!config || !config.clientId || !config.apiKey) {
                throw new Error('Google Drive integration is not configured. Please contact the administrator.');
            }

            await loadGoogleScripts();

            if (createGoogleAccessToken) {
                createAndShowCreatePicker(config);
                return;
            }

            createGoogleTokenClient = google.accounts.oauth2.initTokenClient({
                client_id: config.clientId,
                scope: 'https://www.googleapis.com/auth/drive.readonly',
                callback: function(tokenResponse) {
                    if (tokenResponse && tokenResponse.access_token) {
                        createGoogleAccessToken = tokenResponse.access_token;
                        loadingEl.style.display = 'none';
                        pickerBtn.disabled = false;
                        createAndShowCreatePicker(config);
                    } else {
                        loadingEl.style.display = 'none';
                        pickerBtn.disabled = false;
                        createShowGoogleDriveError('Authentication failed. Please try again.');
                    }
                },
                error_callback: function(error) {
                    loadingEl.style.display = 'none';
                    pickerBtn.disabled = false;
                    createShowGoogleDriveError('Authentication was cancelled or failed.');
                }
            });

            loadingEl.style.display = 'none';
            pickerBtn.disabled = false;
            createGoogleTokenClient.requestAccessToken({ prompt: '' });

        } catch (error) {
            console.error('Google Drive Picker error:', error);
            loadingEl.style.display = 'none';
            pickerBtn.disabled = false;
            createShowGoogleDriveError(error.message || 'Failed to open Google Drive. Please try again.');
        }
    }

    function createAndShowCreatePicker(config) {
        if (!createGoogleAccessToken) {
            createShowGoogleDriveError('Google Picker is not ready. Please try again.');
            return;
        }

        try {
            var allowedMimeTypes = [
                'application/pdf','image/jpeg','image/png','image/gif',
                'text/csv','text/plain','application/msword',
                'application/vnd.openxmlformats-officedocument.wordprocessingml.document',
                'application/vnd.ms-excel',
                'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet',
                'application/vnd.google-apps.document',
                'application/vnd.google-apps.spreadsheet'
            ].join(',');

            var docsView = new google.picker.DocsView(google.picker.ViewId.DOCS)
                .setMimeTypes(allowedMimeTypes)
                .setIncludeFolders(false)
                .setSelectFolderEnabled(false)
                .setMode(google.picker.DocsViewMode.LIST);

            var picker = new google.picker.PickerBuilder()
                .setAppId(config.appId)
                .setOAuthToken(createGoogleAccessToken)
                .setDeveloperKey(config.apiKey)
                .addView(docsView)
                .setSelectableMimeTypes(allowedMimeTypes)
                .setCallback(createPickerCallback)
                .setTitle('Select a Document from Google Drive')
                .setMaxItems(1)
                .build();

            picker.setVisible(true);
        } catch (error) {
            console.error('Error creating picker:', error);
            createShowGoogleDriveError('Failed to open file picker. Please try again.');
        }
    }

    function createPickerCallback(data) {
        if (data.action === google.picker.Action.PICKED) {
            var file = data.docs[0];
            if (file) {
                document.getElementById('createPatientGoogleFileId').value = file.id;
                document.getElementById('createPatientGoogleAccessToken').value = createGoogleAccessToken;

                var selectedEl = document.getElementById('createGoogleDriveSelectedFile');
                var fileNameEl = document.getElementById('createGoogleDriveFileName');
                var pickerBtn = document.getElementById('createGoogleDrivePickerBtn');
                var errorEl = document.getElementById('createGoogleDriveError');

                fileNameEl.textContent = file.name;
                selectedEl.style.display = 'flex';
                pickerBtn.style.display = 'none';
                if (errorEl) errorEl.style.display = 'none';
            }
        }
    }

    function createClearGoogleDriveSelection() {
        var fileIdEl = document.getElementById('createPatientGoogleFileId');
        var tokenEl = document.getElementById('createPatientGoogleAccessToken');
        var selectedEl = document.getElementById('createGoogleDriveSelectedFile');
        var pickerBtn = document.getElementById('createGoogleDrivePickerBtn');
        var errorEl = document.getElementById('createGoogleDriveError');

        if (fileIdEl) fileIdEl.value = '';
        if (tokenEl) tokenEl.value = '';
        if (selectedEl) selectedEl.style.display = 'none';
        if (pickerBtn) pickerBtn.style.display = '';
        if (errorEl) errorEl.style.display = 'none';
    }

    function createShowGoogleDriveError(message) {
        var errorEl = document.getElementById('createGoogleDriveError');
        var errorMsg = document.getElementById('createGoogleDriveErrorMsg');
        if (errorEl && errorMsg) {
            errorMsg.textContent = message;
            errorEl.style.display = 'flex';
        }
    }

    // ── Reset modal on open ──────────────────────────────────────────────────
    document.addEventListener('DOMContentLoaded', function () {
        var createModal = document.getElementById('createPatientModal');
        if (createModal) {
            createModal.addEventListener('show.bs.modal', function () {
                // Set current datetime
                var now = new Date();
                var year = now.getFullYear();
                var month = String(now.getMonth() + 1).padStart(2, '0');
                var day = String(now.getDate()).padStart(2, '0');
                var hours = String(now.getHours()).padStart(2, '0');
                var minutes = String(now.getMinutes()).padStart(2, '0');
                var formatted = year + '-' + month + '-' + day + 'T' + hours + ':' + minutes;
                var input = createModal.querySelector('input[name="VisitedAt"]');
                if (input) { input.value = formatted; }

                // Reset upload source to device
                createSelectUploadSource('device');

                if (typeof refreshInfields === 'function') refreshInfields(createModal);
            });
        }
    });
</script>
