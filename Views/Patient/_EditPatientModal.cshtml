@model DMS_CPMS.Models.Patient.EditPatientViewModel

<div class="modal fade" id="editPatientModal" tabindex="-1" aria-labelledby="editPatientModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content ocean-modal">
            <div class="modal-header">
                <h5 class="modal-title" id="editPatientModalLabel">Edit Patient</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="Edit" asp-controller="Patient" method="post">
                <div class="modal-body">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="PatientID" />
                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="infield">
                                <input asp-for="FirstName" class="form-control" />
                                <label asp-for="FirstName" class="infield-label"></label>
                            </div>
                            <span asp-validation-for="FirstName" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <div class="infield">
                                <input asp-for="LastName" class="form-control" />
                                <label asp-for="LastName" class="infield-label"></label>
                            </div>
                            <span asp-validation-for="LastName" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <div class="infield">
                                <input asp-for="BirthDate" type="date" class="form-control" min="1900-01-01" max="@DateTime.Today.ToString("yyyy-MM-dd")" />
                                <label asp-for="BirthDate" class="infield-label"></label>
                            </div>
                            <span asp-validation-for="BirthDate" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <div class="infield">
                                <select asp-for="Gender" class="form-select">
                                    <option value="Male">Male</option>
                                    <option value="Female">Female</option>
                                </select>
                                <label asp-for="Gender" class="infield-label"></label>
                            </div>
                            <span asp-validation-for="Gender" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <div class="infield">
                                <input asp-for="VisitedAt" type="datetime-local" class="form-control" />
                                <label asp-for="VisitedAt" class="infield-label"></label>
                            </div>
                            <span asp-validation-for="VisitedAt" class="text-danger"></span>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary" id="editPatientSubmitBtn">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    (function () {
        function validateEditPatientBirthDate() {
            var birthInput = document.querySelector('#editPatientModal input[name="BirthDate"]');
            var submitBtn = document.getElementById('editPatientSubmitBtn');
            if (!birthInput || !submitBtn) return;

            var val = birthInput.value;
            if (!val) { submitBtn.disabled = false; return; }

            var date = new Date(val);
            var minDate = new Date('1900-01-01');
            var today = new Date();
            today.setHours(23, 59, 59, 999);

            var errorSpan = birthInput.closest('.col-md-6').querySelector('.text-danger');

            if (date < minDate) {
                if (errorSpan) errorSpan.textContent = 'Birth date must be after January 1, 1900.';
                submitBtn.disabled = true;
            } else if (date > today) {
                if (errorSpan) errorSpan.textContent = 'Birth date cannot be in the future.';
                submitBtn.disabled = true;
            } else {
                if (errorSpan) errorSpan.textContent = '';
                submitBtn.disabled = false;
            }
        }

        document.addEventListener('DOMContentLoaded', function () {
            var editModal = document.getElementById('editPatientModal');
            if (editModal) {
                var birthInput = editModal.querySelector('input[name="BirthDate"]');
                if (birthInput) {
                    birthInput.addEventListener('change', validateEditPatientBirthDate);
                    birthInput.addEventListener('input', validateEditPatientBirthDate);
                }
                editModal.addEventListener('show.bs.modal', function () {
                    var btn = document.getElementById('editPatientSubmitBtn');
                    if (btn) btn.disabled = false;
                    var span = editModal.querySelector('span[data-valmsg-for="BirthDate"]') ||
                               (birthInput && birthInput.closest('.col-md-6') ? birthInput.closest('.col-md-6').querySelector('.text-danger') : null);
                    if (span) span.textContent = '';
                });
            }
        });
    })();
</script>
