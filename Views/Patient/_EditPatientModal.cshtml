@model DMS_CPMS.Models.Patient.EditPatientViewModel

<div class="modal fade" id="editPatientModal" tabindex="-1" aria-labelledby="editPatientModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content ocean-modal">
            <div class="modal-header">
                <h5 class="modal-title" id="editPatientModalLabel">Edit Patient</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-action="Edit" asp-controller="Patient" method="post">
                <div class="modal-body">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="PatientID" />
                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="infield">
                                <input asp-for="FirstName" class="form-control" />
                                <label asp-for="FirstName" class="infield-label"></label>
                            </div>
                            <span asp-validation-for="FirstName" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <div class="infield">
                                <input asp-for="LastName" class="form-control" />
                                <label asp-for="LastName" class="infield-label"></label>
                            </div>
                            <span asp-validation-for="LastName" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <div class="infield">
                                <input asp-for="BirthDate" type="date" class="form-control" />
                                <label asp-for="BirthDate" class="infield-label"></label>
                            </div>
                            <span asp-validation-for="BirthDate" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <div class="infield">
                                <select asp-for="Gender" class="form-select">
                                    <option value="Male">Male</option>
                                    <option value="Female">Female</option>
                                </select>
                                <label asp-for="Gender" class="infield-label"></label>
                            </div>
                            <span asp-validation-for="Gender" class="text-danger"></span>
                        </div>
                        <div class="col-md-6">
                            <div class="infield">
                                <input asp-for="VisitedAt" type="datetime-local" class="form-control" />
                                <label asp-for="VisitedAt" class="infield-label"></label>
                            </div>
                            <span asp-validation-for="VisitedAt" class="text-danger"></span>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>
