@model DMS_CPMS.Models.Reports.ReportsIndexViewModel
@{
    Layout = null;
    var reportTitle = Model.SelectedReport ?? "Report";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Report - @reportTitle</title>
    <link rel="stylesheet" href="/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
        body { font-size: 12px; padding: 20px; }
        .report-section { page-break-inside: avoid; margin-bottom: 20px; }
        .report-section-header { background: #006d77; color: #fff; padding: 8px 14px; }
        .report-section-header h6 { color: #fff; margin: 0; }
        .report-section-header .text-muted { color: rgba(255,255,255,0.75) !important; }
        table { font-size: 11px; }
        .table-footer, .pagination-nav { display: none; }
        .print-header { text-align: center; margin-bottom: 20px; border-bottom: 2px solid #006d77; padding-bottom: 10px; }
        .print-header h4 { color: #006d77; margin: 0; }
        .print-header small { color: #666; }
        .badge { font-size: 10px; }
        @@media print {
            .no-print { display: none !important; }
            .report-section { page-break-inside: avoid; }
        }
    </style>
</head>
<body>
    <div class="print-header">
        <h4>DMS CPMS - @reportTitle</h4>
        <small>
            Generated on @DateTime.Now.ToString("MMMM dd, yyyy hh:mm tt")
            @if (!string.IsNullOrEmpty(Model.DateFrom) || !string.IsNullOrEmpty(Model.DateTo))
            {
                <text>&nbsp;|&nbsp; Date Range: @(Model.DateFrom ?? "Start") to @(Model.DateTo ?? "Present")</text>
            }
        </small>
    </div>

    <div class="no-print text-center mb-3">
        <button class="btn btn-primary btn-sm" onclick="window.print()">Print This Page</button>
        <button class="btn btn-secondary btn-sm" onclick="window.close()">Close</button>
    </div>

    @if (Model.PatientSummary != null)
    {
        <partial name="~/Views/Shared/Reports/_PatientSummaryReport.cshtml" model="Model" />
    }
    @if (Model.DocumentActivity != null)
    {
        <partial name="~/Views/Shared/Reports/_DocumentActivityReport.cshtml" model="Model" />
    }
    @if (Model.AuditLogs != null)
    {
        <partial name="~/Views/Shared/Reports/_AuditLogsReport.cshtml" model="Model" />
    }

    <script>
        // Auto-trigger print dialog
        window.onload = function() { window.print(); };
    </script>
</body>
</html>
