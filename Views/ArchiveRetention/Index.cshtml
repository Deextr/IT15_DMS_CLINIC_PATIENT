                @Html.AntiForgeryToken()
                <input type="hidden" name="RetentionPolicyID" id="editPolicyId" />
                <input type="hidden" name="RetentionDurationMonths" id="editPolicyDurationHidden" />
                <div class="modal-body">
                    <div class="infield mb-3">
                        <select name="ModuleName" id="editPolicyModuleName" class="form-select" required>
                            <option value="" disabled>Select a document type</option>
                            <option value="Medical History">Medical History</option>
                            <option value="Examination Reports">Examination Reports</option>
                            <option value="Lab Reports">Lab Reports</option>
                            <option value="Imaging Reports">Imaging Reports</option>
                            <option value="Prescription Records">Prescription Records</option>
                            <option value="Others">Others</option>
                        </select>
                        <label class="infield-label" for="editPolicyModuleName">Document Type</label>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold" style="font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.02em; color: var(--color-text-muted); font-weight: 600;">Retention Duration</label>
                        <div class="row g-2">
                            <div class="col-7">
                                <div class="infield">
                                    <input type="number" class="form-control" id="editPolicyDurationValue" min="1" max="100" required />
                                    <label class="infield-label" for="editPolicyDurationValue">Value</label>
                                </div>
                            </div>
                            <div class="col-5">
                                <div class="infield">
                                    <select class="form-select" id="editPolicyDurationUnit">
                                        <option value="months">Months</option>
                                        <option value="years">Years</option>
                                    </select>
                                    <label class="infield-label" for="editPolicyDurationUnit">Unit</label>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="infield mb-3">
                        <select name="AutoActionAfterExpiry" id="editPolicyAutoAction" class="form-select" required>
                            <option value="ManualReview">Manual Review Required</option>
                            <option value="AutoDelete">Auto Delete</option>
                        </select>
                        <label class="infield-label" for="editPolicyAutoAction">Auto Action After Expiry</label>
                    </div>
                    <div class="form-check mb-3">
                        <input type="hidden" name="IsEnabled" value="false" />
                        <input class="form-check-input" type="checkbox" name="IsEnabled" value="true" id="editPolicyEnabled" />
                        <label class="form-check-label" for="editPolicyEnabled">Policy Enabled</label>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Update Policy</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Restore Account Confirmation Modal -->
<div class="modal fade" id="restoreAccountModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content ocean-modal">
            <div class="modal-header">
                <h5 class="modal-title">Confirm Restore</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="RestoreAccount" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" id="restoreAccountId" />
                <div class="modal-body text-center">
                    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-success mb-3"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"></path><path d="M3 3v5h5"></path></svg>
                    <p>Are you sure you want to restore<br/><strong id="restoreAccountName"></strong>?</p>
                    <small class="text-muted">The account will be moved back to the accounts list. Note: the account will remain deactivated and will need to be manually activated.</small>
                </div>
                <div class="modal-footer justify-content-center">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-success">Yes, Restore</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/archive-retention.js" asp-append-version="true"></script>
    <script>
        function openRestoreAccountModal(btn) {
            var id = btn.getAttribute('data-account-id');
            var name = btn.getAttribute('data-account-name');
            document.getElementById('restoreAccountId').value = id || '';
            document.getElementById('restoreAccountName').textContent = name || '';
            var modal = new bootstrap.Modal(document.getElementById('restoreAccountModal'));
            modal.show();
        }

        function goToAccountPage(page) {
            var url = new URL(window.location.href);
            url.searchParams.set('accountPage', page);
            url.hash = '#archived-accounts-table';
            // Activate the accounts tab on page load
            url.searchParams.set('activeTab', 'accounts');
            window.location.href = url.toString();
        }

        // Auto-activate correct tab based on URL param
        document.addEventListener('DOMContentLoaded', function () {
            var url = new URL(window.location.href);
            var activeTab = url.searchParams.get('activeTab');
            if (activeTab === 'accounts') {
                var tab = document.getElementById('archived-accounts-tab');
                if (tab) new bootstrap.Tab(tab).show();
            } else if (activeTab === 'policies') {
                var tab = document.getElementById('retention-policy-tab');
                if (tab) new bootstrap.Tab(tab).show();
            }
            // Also activate if accountSearchTerm is present
            var acctSearch = url.searchParams.get('accountSearchTerm');
            if (acctSearch) {
                var tab = document.getElementById('archived-accounts-tab');
                if (tab) new bootstrap.Tab(tab).show();
            }
        });
    </script>
}
